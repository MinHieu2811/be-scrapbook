{
  "name": "be-scrapbook",
  "version": "1.0.0",
  "description": "Birthday Scrapbook CRUD API — Express.js + TypeScript + Supabase",
  "main": "api/index.ts",
  "scripts": {
    "dev": "nodemon --watch src --watch api --ext ts --exec tsx api/index.ts",
    "build": "tsc",
    "start": "node dist/api/index.js",
    "lint": "eslint 'src/**/*.ts' 'api/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'api/**/*.ts'"
  },
  "keywords": [
    "scrapbook",
    "birthday",
    "express",
    "supabase",
    "vercel"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
